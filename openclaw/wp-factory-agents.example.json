{
  "note": "Sanitized WP Factory OpenClaw agent registration example. Copy/merge these entries into the target OpenClaw config and adjust paths. No secrets are included.",
  "mainSubagentAllowListAdditions": [
    "wp-producer",
    "wp-brand-agent",
    "wp-copy-agent",
    "wp-builder",
    "wp-qa-agent"
  ],
  "agents": [
    {
      "id": "wp-producer",
      "name": "WP 1 Producer (Wendy)",
      "workspace": "<path-to-cloned-wp-factory-repo>",
      "agentDir": "<openclaw-agents-dir>/wp-producer",
      "model": {
        "primary": "openai/gpt-5.5",
        "fallbacks": [
          "openai/gpt-5.4-mini"
        ]
      },
      "models": {
        "openai/gpt-5.5": {
          "agentRuntime": {
            "id": "codex"
          }
        },
        "openai/gpt-5.4-mini": {
          "agentRuntime": {
            "id": "codex"
          }
        }
      },
      "tools": {
        "deny": [
          "message",
          "gateway",
          "memory_search",
          "memory_get",
          "cron",
          "weather",
          "x_search",
          "image_generate",
          "video_generate",
          "music_generate",
          "tts",
          "agents_list",
          "nodes"
        ],
        "profile": "coding",
        "alsoAllow": [
          "browser",
          "update_plan"
        ]
      },
      "subagents": {
        "allowAgents": [
          "wp-brand-agent",
          "wp-copy-agent",
          "wp-builder",
          "wp-qa-agent"
        ]
      }
    },
