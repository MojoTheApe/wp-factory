{
  "note": "Sanitized WP Factory OpenClaw agent registration example. Copy/merge these entries into the target OpenClaw config and adjust paths. No secrets are included.",
  "mainSubagentAllowListAdditions": [
    "wp-1-wendy",
    "wp-2-brenda",
    "wp-3-cora",
    "wp-4-billy",
    "wp-5-quentin"
  ],
  "agents": [
    {
      "id": "wp-1-wendy",
      "name": "WP Producer",
      "workspace": "<path-to-cloned-wp-factory-repo>",
      "agentDir": "<openclaw-agents-dir>/wp-1-wendy",
      "model": {
        "primary": "openai/gpt-5.5",
        "fallbacks": [
          "openai/gpt-5.4-mini"
        ]
      },
      "models": {
        "openai/gpt-5.5": {
          "agentRuntime": {
            "id": "codex"
          }
        },
        "openai/gpt-5.4-mini": {
          "agentRuntime": {
            "id": "codex"
          }
        }
      },
      "tools": {
        "deny": [
          "message",
          "gateway",
          "memory_search",
          "memory_get",
          "cron",
          "weather",
          "x_search",
          "image_generate",
          "video_generate",
          "music_generate",
          "tts",
          "agents_list",
          "nodes"
        ],
        "profile": "coding",
        "alsoAllow": [
          "browser",
          "update_plan"
        ]
      },
      "subagents": {
        "allowAgents": [
