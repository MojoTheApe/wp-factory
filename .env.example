WORDPRESS_PORT=8088
WORDPRESS_DB_NAME=wp_factory
WORDPRESS_DB_USER=wp_factory
WORDPRESS_DB_PASSWORD=wp_factory_password
MYSQL_ROOT_PASSWORD=wp_factory_root_password
WORDPRESS_DEBUG=1

# Optional. When present, generated sites select stock images through Pexels.
# Without this key, previews use temporary Unsplash Source placeholder URLs.
PEXELS_API_KEY=
